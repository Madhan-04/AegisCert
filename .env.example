# AegisCert Environment Configuration

# Production Mode Persistence (Standard Source of Truth)
# Supabase PostgreSQL connection details. Required in production!
VITE_SUPABASE_URL=https://your-supabase-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Legacy Local Fallbacks & Dev Configuration
# Local Express REST API Server URL
VITE_API_URL=http://localhost:5000

# Express Server Configuration (server/index.js)
PORT=5000
JWT_SECRET=your-secure-random-jwt-signing-key-here-minimum-32-chars
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5000
